<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Subway-like Runner</title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <style>
    :root {
      --bg: var(--tg-theme-bg-color, #1a1a1a);
      --text: var(--tg-theme-text-color, #ffffff);
      --accent: var(--tg-theme-button-color, #ff4757);
    }
    body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      overflow: hidden;
      touch-action: none;
    }
    #game-container {
      position: relative;
      width: 640px;
      height: 360px;
      margin: auto;
      border: 2px solid rgba(255,255,255,0.1);
      box-sizing: border-box;
      user-select: none;
      -webkit-user-select: none;
    }
    canvas {
      display: block;
      width: 100%;
      height: 100%;
    }
    #ui-layer {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      pointer-events: none;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 12px;
      box-sizing: border-box;
    }
    .score-board {
      font-size: 20px;
      font-weight: bold;
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    #start-screen, #game-over-screen {
      position: absolute;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.85);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      pointer-events: auto;
      text-align: center;
    }
    button {
      background: var(--accent);
      color: white;
      border: none;
      padding: 14px 28px;
      font-size: 18px;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 16px;
      font-weight: bold;
    }
    button:active {
      transform: scale(0.96);
    }
  </style>
</head>
<body>
  <div id="game-container">
    <canvas id="gameCanvas" width="640" height="360"></canvas>

    <div id="ui-layer">
      <div class="score-board">Счёт: <span id="scoreEl">0</span></div>
      <!-- сюда можно добавить ещё UI при необходимости -->
    </div>

    <!-- Экран старта -->
    <div id="start-screen">
      <h2>Subway Runner</h2>
      <p>Двигайся влево/вправо, избегай препятствий</p>
      <button id="btnStart">Начать</button>
    </div>

    <!-- Экран Game Over -->
    <div id="game-over-screen" style="display:none;">
      <h2>Game Over</h2>
      <p>Счёт: <span id="finalScore">0</span></p>
      <button id="btnRestart">Ещё раз</button>
    </div>
  </div>

  <script>
    const tg = window.Telegram.WebApp;
    tg.ready();
    tg.expand();

    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    const scoreEl = document.getElementById('scoreEl');
    const finalScore = document.getElementById('finalScore');

    const btnStart = document.getElementById('btnStart');
    const btnRestart = document.getElementById('btnRestart');
    const startScreen = document.getElementById('start-screen');
    const gameOverScreen = document.getElementById('game-over-screen');

    // Параметры мира
    const lanes = 3;
    const laneWidth = canvas.width / lanes;
    const playerSize = 40;
    const obstacleSize = 50;

    let playerLane = 1; // центральная полоса
    let obstacles = [];
    let frame = 0;
    let speed = 4;
    let score = 0;
    let gameActive = false;
    let animationFrameId;

    function resetGame() {
      playerLane = 1;
      obstacles = [];
      frame = 0;
      speed = 4;
      score = 0;
      scoreEl.textContent = score;
      gameActive = true;
      cancelAnimationFrame(animationFrameId);
      loop();
    }

    function spawnObstacle() {
      const lane = Math.floor(Math.random() * lanes);
      // немного смещаем, чтобы не спавнились ровно по центру
      const x = lane * laneWidth + laneWidth/2 - obstacleSize/2;
      const y = -obstacleSize;
      obstacles.push({ x, y, lane });
    }

    function update() {
      if (!gameActive) return;

      frame++;
      // Увеличение сложности
      if (frame % 60 === 0) speed += 0.2;

      // Спавн препятствий
      if (frame % (60 - Math.min(20, Math.floor(speed))) === 0) {
        spawnObstacle();
      }

      // Движение препятствий
      for (let i = obstacles.length - 1; i >= 0; i--) {
        obstacles[i].y += speed;
        // Удаление ушедших вниз
        if (obstacles[i].y > canvas.height) {
          obstacles.splice(i, 1);
          score++;
          scoreEl.textContent = score;
        }
      }

      // Коллизии
      const playerX = playerLane * laneWidth + laneWidth/2 - playerSize/2;
      const playerY = canvas.height - playerSize - 20; // чуть выше низа

      for (const o of obstacles) {
        if (
          playerX < o.x + obstacleSize &&
          playerX + playerSize > o.x &&
          playerY < o.y + obstacleSize &&
          playerY + playerSize > o.y
        ) {
          gameOver();
          return;
        }
      }
    }

    function draw() {
      ctx.fillStyle = '#1a1a2e';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Дорожка (три полосы)
      ctx.strokeStyle = 'rgba(255,255,255,0.15)';
      ctx.lineWidth = 2;
      for (let l = 1; l < lanes; l++) {
        const x = l * laneWidth;
        ctx.beginPath();
        ctx.moveTo(x, 0);
        ctx.lineTo(x, canvas.height);
        ctx.stroke();
      }

      // Препятствия
      ctx.fillStyle = '#ff4757';
      for (const o of obstacles) {
        ctx.fillRect(o.x, o.y, obstacleSize, obstacleSize);
      }

      // Игрок
      ctx.fillStyle = '#1dd1a1';
      ctx.fillRect(
        playerLane * laneWidth + laneWidth/2 - playerSize/2,
        canvas.height - playerSize - 20,
        playerSize,
        playerSize
      );
    }

    function loop() {
      update();
      draw();
      if (gameActive) {
        animationFrameId = requestAnimationFrame(loop);
      }
    }

    function gameOver() {
      gameActive = false;
      finalScore.textContent = score;
      startScreen.style.display = 'none';
      gameOverScreen.style.display = 'flex';
    }

    // Управление
    function moveLane(direction) {
      if (!gameActive) return;
      let next = playerLane + direction;
      if (next >= 0 && next < lanes) {
        playerLane = next;
      }
    }

    // Тач-управление
    let touchStartX = 0;
    canvas.addEventListener('touchstart', e => {
      touchStartX = e.touches[0].clientX;
    });
    canvas.addEventListener('touchend', e => {
      const touchEndX = e.changedTouches[0].clientX;
      const diff = touchEndX - touchStartX;
      if (diff < -50) moveLane(-1); // влево
      if (diff > 50) moveLane(1);   // вправо
    });

    // Клавиатура
    document.addEventListener('keydown', e => {
      if (e.key === 'a' || e.key === 'ArrowLeft') moveLane(-1);
      if (e.key === 'd' || e.key === 'ArrowRight') moveLane(1);
    });

    btnStart.addEventListener('click', () => {
      startScreen.style.display = 'none';
      resetGame();
    });
    btnRestart.addEventListener('click', () => {
      gameOverScreen.style.display = 'none';
      resetGame();
    });
  </script>
</body>
</html>
