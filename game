<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Subway Text Runner</title>
    <!-- Подключение официального SDK Telegram -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { margin: 0; background-color: #f0f0f0; overflow: hidden; font-family: Arial, sans-serif; }
        #gameCanvas { display: block; margin: auto; background: #7cfc00; border: 2px solid black; }
        #controls {
            position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
            display: flex; gap: 20px;
        }
        .btn {
            width: 60px; height: 60px; font-size: 24px; cursor: pointer;
            background: var(--tg-theme-button-color, #4a90e2); 
            color: var(--tg-theme-button-text-color, white);
            border: none; border-radius: 10px;
        }
    </style>
</head>
<body>
    <canvas id="gameCanvas" width="300" height="400"></canvas>
    
    <div id="controls">
        <button class="btn" onclick="changeLane('left')">←</button>
        <button class="btn" onclick="jump()">↑</button>
        <button class="btn" onclick="changeLane('right')">→</button>
    </div>

    <script src="game.js"></script>
</body>
</html>
game.js
Здесь реализована упрощенная логика бесконечного раннера. Вместо сложной физики используются массивы объектов.

let tg = window.Telegram.WebApp;
tg.ready();
// Применяем тему телеграмма к кнопкам
document.documentElement.style.setProperty('--tg-theme-bg-color', tg.themeParams.bg_color);
document.documentElement.style.setProperty('--tg-theme-text-color', tg.themeParams.text_color);

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

const LANES_X = [70, 150, 230]; // Координаты трех полос
let player = { x: LANES_X[1], y: 300, lane: 1 };
let obstacles = [];
let coins = [];
let score = 0;
let speed = 4;
let gameOver = false;

function spawnObstacle() {
    if (Math.random() > 0.8) {
        const lane = Math.floor(Math.random() * 3);
        obstacles.push({ x: LANES_X[lane], y: -50 });
    }
}

function spawnCoin() {
    if (Math.random() > 0.9) {
        const lane = Math.floor(Math.random() * 3);
        coins.push({ x: LANES_X[lane], y: -30 });
    }
}

function changeLane(dir) {
    if (gameOver) return;
    if (dir === 'left' && player.lane > 0) player.lane--;
    if (dir === 'right' && player.lane < 2) player.lane++;
    player.x = LANES_X[player.lane];
}

function jump() {
    // Простая анимация прыжка через изменение Y координаты
    if (player.y > 250) {
        let pos = 300;
        function frame() {
            if (pos > 220) { pos -= 20; player.y = pos; requestAnimationFrame(frame); }
            else if (pos < 300) { pos += 20; player.y = pos; requestAnimationFrame(frame); }
        }
        frame();
    }
}

function checkCollisions() {
    obstacles.forEach(obs => {
        if (obs.y > 280 && obs.y < 320 && obs.x === player.x) {
            gameOver = true;
        }
    });
}

function updateGame() {
    if (gameOver) {
        tg.sendData(JSON.stringify({score: score})); // Отправляем очки боту при проигрыше
        cancelAnimationFrame(gameLoop);
        alert("Игра окончена! Очки: " + score);
        return;
    }

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Рисуем игрока
    ctx.fillStyle = "blue";
    ctx.fillRect(player.x - 15, player.y - 40, 30, 40);

    // Обновление препятствий
    spawnObstacle();
    obstacles.forEach((o, i) => {
        o.y += speed;
        ctx.fillStyle = "red";
        ctx.fillRect(o.x - 15, o.y, 30, 40);
        if (o.y > canvas.height) obstacles.splice(i, 1);
    });

    // Монетки
    spawnCoin();
    coins.forEach((c, i) => {
        c.y += speed;
        ctx.fillStyle = "gold";
        ctx.beginPath(); ctx.arc(c.x, c.y, 10, 0, Math.PI * 2); ctx.fill();
        if (c.y > canvas.height) coins.splice(i, 1);
        if (Math.abs(c.y - player.y) < 30 && Math.abs(c.x - player.x) < 20) {
            score += 10;
            coins.splice(i, 1);
        }
    });

    checkCollisions();
    score += 0.1; // Очки за время

    // Отрисовка счета
    ctx.fillStyle = "black";
    ctx.font = "20px Arial";
    ctx.fillText("Очки: " + Math.floor(score), 10, 30);

    requestAnimationFrame(updateGame);
}

updateGame();
